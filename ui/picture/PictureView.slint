import { AppState } from "../state.slint";

export component PictureView inherits VerticalLayout {
    // 画像の読み込み中かどうか
    in property <bool> is-image-loading: false;
    // 画像の取得に失敗したかどうか
    in property <bool> is-image-error: false;
    // 表示する画像（Cat API または投稿写真）
    in property <image> image <=> image-item.source;
    // 投稿写真モードのとき true（false のときは Cat API 猫画像）
    in property <bool> picture-mode: false;
    // 投稿写真の説明文
    in property <string> picture-description: "";

    alignment: LayoutAlignment.start;
    spacing: 1rem;

    HorizontalLayout {
        alignment: root.picture-mode ? LayoutAlignment.start : LayoutAlignment.center;
        spacing: 0.5rem;

        VerticalLayout {
            alignment: LayoutAlignment.center;
            spacing: 0.5rem;
            vertical-stretch: 1;

            Text {
                vertical-stretch: 0;
                horizontal-alignment: TextHorizontalAlignment.center;
                text: root.picture-mode ? "今日の一枚" : "猫ちゃんの写真";
                font-size: 0.6rem;
                color: AppState.foreground-color;
            }

            image-item := Image {
                horizontal-stretch: 10;
                vertical-stretch: 10;
            }
        }
        if root.picture-mode && root.picture-description != "" : VerticalLayout {
            vertical-stretch: 1;

            Text {
                vertical-stretch: 0;
                horizontal-alignment: TextHorizontalAlignment.center;
                text: root.picture-description;
                font-size: 0.8rem;
                color: AppState.foreground-color;
            }
        }
    }
}
