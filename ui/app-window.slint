import { AppState } from "state.slint";
import { Date, Time } from "types/datetime.slint";
import { Line } from "utils/Line.slint";
import { HeaderDatetime } from "header/HeaderDatetime.slint";
import { ScheduleRow } from "schedule/ScheduleRow.slint";
import { ScheduleList, Schedule } from "schedule/ScheduleList.slint";
import { MessageList, Message } from "messages/MessageList.slint";
import { MessageNotFound } from "messages/MessageNotFound.slint";
import { PictureView } from "picture/PictureView.slint";

export component AppWindow inherits Window {
    title: "Karuma";
    no-frame: true;
    full-screen: true;
    background: AppState.background-color;
    default-font-family: "BIZ UDPゴシック";
    default-font-size: 80px;
    default-font-weight: 200;

    // 今日の日付
    in property <Date> date: {
        month: 3,
        day: 19,
        dayOfWeek: 6,
    };
    // 現在の時刻
    in property <Time> time: {
        hour: 1,
        minute: 0,
    };
    // メッセージのリスト
    in property <[Message]> messages: [
    ];
    //     {
    //         date: {
    //             month: 3,
    //             day: 19,
    //             dayOfWeek: 6,
    //         },
    //         time: {
    //             hour: 12,
    //             minute: 34,
    //         },
    //         author: "まい",
    //         text: "おはよう！まいは今日行かないよー！",
    //     },
    //     {
    //         date: {
    //             month: 3,
    //             day: 19,
    //             dayOfWeek: 6,
    //         },
    //         time: {
    //             hour: 12,
    //             minute: 34,
    //         },
    //         author: "まい",
    //         text: "ヘルパーさんへ　朝ごはんの用意を忘れてしまいました。テーブル上のパンを朝ごはんにしてください。",
    //     },
    //     {
    //         date: {
    //             month: 3,
    //             day: 19,
    //             dayOfWeek: 6,
    //         },
    //         time: {
    //             hour: 12,
    //             minute: 34,
    //         },
    //         author: "めい",
    //         text: "今日はめいが13:30に行きます。",
    //     },
    //     {
    //         date: {
    //             month: 3,
    //             day: 19,
    //             dayOfWeek: 6,
    //         },
    //         time: {
    //             hour: 12,
    //             minute: 34,
    //         },
    //         author: "まい",
    //         text: "明日3/20(祝)のリハビリは、16:10開始から14:30開始に変更です。",
    //     }
    // ];

    in property <bool> is-image-loading: false;
    in property <bool> is-image-error: false;
    in property <image> image;
    // 投稿写真モードのとき true（false のときは catAPI 猫画像）
    in property <bool> picture-mode: false;
    // 投稿写真の説明文
    in property <string> picture-description: "";

    // スケジュールのリスト
    in property <[Schedule]> schedules: [
        // { time-range: "18:00～19:00", title: "予定A （あああ）", is-future: false },
        // { time-range: "20:00～21:00", title: "予定B", is-future: true },
    ];

    callback request-increase-value();

    VerticalLayout {
        padding: 0.75rem;
        spacing: 0.5rem;

        HorizontalLayout {
            alignment: LayoutAlignment.start;
            padding: 0px;
            spacing: 0.5rem;

            HeaderDatetime {
                date: root.date;
                time: root.time;
            }
        }
        Line {}

        Rectangle {
            property <int> active-page: 1;
            property <int> page-count: 3; // ここを増やせば3つ以上に対応できます

            Timer {
                interval: 30s;
                running: true;
                triggered => {
                    parent.active-page += 1;
                    if (parent.active-page >= parent.page-count) {
                        parent.active-page = 0;
                    }
                }
            }

            Rectangle {
                opacity: parent.active-page == 0 ? 1.0 : 0.0;
                animate opacity { duration: 500ms; }

                if root.messages.length == 0 : MessageNotFound {}
                if root.messages.length != 0 : MessageList {
                    messages: root.messages;
                }
            }

            Rectangle {
                opacity: parent.active-page == 1 ? 1.0 : 0.0;
                animate opacity { duration: 500ms; }

                PictureView {
                    is-image-loading: root.is-image-loading;
                    is-image-error: root.is-image-error;
                    image: root.image;
                    picture-mode: root.picture-mode;
                    picture-description: root.picture-description;
                }
            }

            Rectangle {
                opacity: parent.active-page == 2 ? 1.0 : 0.0;
                animate opacity { duration: 500ms; }

                ScheduleList {
                    schedules: root.schedules;
                }
            }

            Rectangle {
                opacity: parent.active-page == 2 ? 1.0 : 0.0;
                animate opacity { duration: 500ms; }

                ScheduleList {
                    schedules: root.schedules;
                }
            }
        }
        // Line {}

        // VerticalLayout {
        //     alignment: LayoutAlignment.end;
        //     spacing: 0.5rem;

        //     ScheduleRow {
        //         is-future: false;
        //     }
        //     ScheduleRow {
        //         is-future: true;
        //         font-size: 0.8;
        //         foreground-color: AppState.foreground-color-secondary;
        //     }
        // }
    }
}
