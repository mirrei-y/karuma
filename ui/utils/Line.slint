import { AppState } from "../state.slint";

export component Line inherits Path {
    width: 100%;
    height: 0.1rem;
    stroke: AppState.foreground-color-secondary;
    stroke-width: root.height;
    stroke-line-cap: LineCap.round;
    opacity: 0.25;

    MoveTo {
        x: 0;
        y: 0;
    }
    LineTo {
        x: 100%;
        y: 0;
    }
}
